<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whatsapp</title>
    <link rel="stylesheet" href="/chat.css">
</head>
<body>
    <h1>All Chats</h1>
    <%for(let chat of chats){%>
        <div class="chat">
           <p>From :<%= chat.from%></p>
          <div class="msg">
            <p class="msg">Msg : <%=chat.msg%>
                <form method="get" action="/chats/<%=chat._id%>/edit">
                   <button>Edit</button>
                </form>
                <br>
                <form method="post" action="/chats/<%=chat._id%>?_method=DELETE">
                   <button>Delete</button>
                </form>
            </p> 
          </div>
           <p>To : <%=chat.to%></p>
           <hr>
           <p><%=chat.created_at.toString().split(" ")[4]%></p>
            <p><%=chat.created_at.toString().split(" ").slice(0,4).join(" ")%></p>
        </div>
        <br>
        <br>
   <% }%>

   <form method="get" action="/chats/new">
        <button>Click for New Chat</button>
    </form>
</body>
</html>